# API
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://bruma:bruma@localhost:5432/bruma
REDIS_URL=redis://localhost:6379
# Single shared key for MVP dashboard + tooling (rotate in staging/prod)
ADMIN_API_KEY=change-me-in-staging
ALLOWED_ORIGINS=http://localhost:5173

# Request timeout (ms) — Fastify
REQUEST_TIMEOUT_MS=30000

# Global API rate limits (in-memory; per API key hash + per tenant)
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_MAX=300
API_RATE_LIMIT_MAX_TENANT=600
API_RATE_LIMIT_WINDOW_MS=60000

# Swagger UI + OpenAPI JSON/YAML (default on in non-production)
# OPENAPI_DOCS_ENABLED=true

# Web (Vite)
VITE_API_BASE_URL=http://localhost:3000

# Webhook (later sprints)
WEBHOOK_SECRET=
