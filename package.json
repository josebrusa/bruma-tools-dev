{
  "name": "bruma-tools-dev",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter @bruma/web run test:e2e",
    "dev:web": "pnpm --filter @bruma/web run dev",
    "dev:api": "pnpm --filter @bruma/api run dev"
  }
}
